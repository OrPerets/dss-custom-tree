{
  "meta": {
    "label": "Amdocs workforce org designer",
    "description": "Load workforce hierarchy datasets and open the interactive org-design workspace",
    "icon": "icon-sitemap"
  },

  "hideWebAppConfig": false,
  "baseType": "STANDARD",
  "standardWebAppLibraries": ["dataiku", "font_awesome"],
  "hasBackend": "true",
  "noJSSecurity": "true",

  "params": [
    {
      "type": "SEPARATOR",
      "label": "Source defaults"
    },
    {
      "name": "default_employee_dataset",
      "type": "DATASET",
      "label": "Input workforce dataset",
      "mandatory": true
    },
    {
      "name": "default_constraints_dataset",
      "type": "DATASET",
      "label": "Default rules dataset",
      "mandatory": false
    },
    {
      "type": "SEPARATOR",
      "label": "Saved baselines"
    },
    {
      "name": "snapshot_folder",
      "type": "FOLDER",
      "label": "Baseline folder",
      "mandatory": false
    }
  ]
}
